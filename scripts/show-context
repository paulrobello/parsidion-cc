#!/usr/bin/env bash
# Show what vault context would be injected for a project session start.
#
# Usage: show-context [folder]
#   folder  Project directory to check (default: current directory)
#
# Requires: jq, python3
#
# Examples:
#   ./scripts/show-context                    # Preview context for cwd
#   ./scripts/show-context ~/Repos/myproject  # Preview context for a specific project

set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    sed -n '2,/^$/s/^# \?//p' "$0"
    exit 0
fi

FOLDER="${1:-$(pwd)}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

python "$REPO_ROOT/skills/parsidion-cc/scripts/session_start_hook.py" <<EOF | jq -r '.hookSpecificOutput.additionalContext'
{"cwd": "$FOLDER"}
EOF
